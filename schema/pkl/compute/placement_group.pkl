module hcloud.compute.placement_group

import "@formae/formae.pkl"
import "../hcloud.pkl"

const type = "HETZNER::Compute::PlacementGroup"

open class PlacementGroupResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden id: PlacementGroupResolvable = (this) {
        property = "id"
    }
}

@hcloud.ResourceHint {
    type = module.type
    identifier = "id"
    portable = true
}
open class PlacementGroup extends formae.Resource {
    @hcloud.FieldHint {
        required = true
    }
    name: String

    @hcloud.FieldHint {
        required = true
        createOnly = true
    }
    type: String

    @hcloud.FieldHint { hasProviderDefault = true }
    labels: Mapping<String, String>?

    @hcloud.FieldHint { hasProviderDefault = true }
    id: Int?

    @hcloud.FieldHint { hasProviderDefault = true }
    servers: Listing<Int>?

    local parent = this

    hidden res: PlacementGroupResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
