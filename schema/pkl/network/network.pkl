module hcloud.network.network

import "@formae/formae.pkl"
import "../hcloud.pkl"

const type = "HETZNER::Network::Network"

open class NetworkResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden id: NetworkResolvable = (this) {
        property = "id"
    }
}

@hcloud.ResourceHint {
    type = module.type
    identifier = "id"
    portable = true
}
open class Network extends formae.Resource {
    @hcloud.FieldHint {
        required = true
    }
    name: String

    @hcloud.FieldHint {
        required = true
        createOnly = true
    }
    ipRange: String

    @hcloud.FieldHint { hasProviderDefault = true }
    labels: Mapping<String, String>?

    @hcloud.FieldHint { hasProviderDefault = true }
    id: Int?

    @hcloud.FieldHint { hasProviderDefault = true }
    exposeRoutesToV2: Boolean?

    local parent = this

    hidden res: NetworkResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
