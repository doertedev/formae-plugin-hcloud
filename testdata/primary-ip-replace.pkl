amends "@formae/forma.pkl"

import "@hcloud/network/primary_ip.pkl"

import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new primary_ip.PrimaryIP {
    label = "primary-ip-\(v.testRunID)"
    name = "formae-conf-primary-ip-\(v.testRunID)-replaced"
    type = "ipv6"
    location = v.location
    autoDelete = false
    labels = new Mapping {
      ["owner"] = "formae-conformance-test"
      ["phase"] = "replace"
    }
  }
}
