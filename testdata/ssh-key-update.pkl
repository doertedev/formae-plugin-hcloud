amends "@formae/forma.pkl"

import "@hcloud/security/ssh_key.pkl"

import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new ssh_key.SSHKey {
    label = "ssh-key-\(v.testRunID)"
    name = "formae-conf-ssh-key-\(v.testRunID)-updated"
    publicKey = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIF0CkeuGnTQMsq8I/dlg2B91UY7zBTYfAUQJe61Okxf3 formae-conformance-test"
    labels = new Mapping {
      ["owner"] = "formae-conformance-test"
      ["phase"] = "update"
    }
  }
}
