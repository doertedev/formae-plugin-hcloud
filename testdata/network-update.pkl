amends "@formae/forma.pkl"

import "@hcloud/network/network.pkl"

import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new network.Network {
    label = "network-\(v.testRunID)"
    name = "formae-conf-network-\(v.testRunID)-updated"
    ipRange = "10.0.0.0/16"
    labels = new Mapping {
      ["owner"] = "formae-conformance-test"
      ["phase"] = "update"
    }
  }
}
